{
  "title": "TrekRank API Overview",
  "uid": "trekrank-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "API p95 latency by route",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"trekrank-api\"}[5m])) by (le, handler))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests handled / throughput (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"trekrank-api\"}[5m])) by (handler, status)",
          "legendFormat": "{{handler}} [{{status}}]"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Itinerary generation p95 (sub-200ms target)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(trekrank_itinerary_generation_seconds_bucket{kind=\"single_day\"}[5m])) by (le))",
          "legendFormat": "single_day p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Itineraries generated (rate/s)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(trekrank_itineraries_generated_total[5m])) by (kind)",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Itineraries generated (total)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(trekrank_itineraries_generated_total)",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "PostGIS geospatial query latency (p50 / p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(trekrank_postgis_query_seconds_bucket[5m])) by (le, query_type))",
          "legendFormat": "p50 {{query_type}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(trekrank_postgis_query_seconds_bucket[5m])) by (le, query_type))",
          "legendFormat": "p95 {{query_type}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP error rate (5xx)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"trekrank-api\", status=\"5xx\"}[5m]))",
          "legendFormat": "5xx/s"
        }
      ]
    }
  ]
}

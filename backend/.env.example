# Copy to .env and adjust. Defaults target a native (no-Docker) local setup.
DATABASE_URL=postgresql+psycopg2://saillesh@localhost:5432/trekrank
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256

# local | s3
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./media
PUBLIC_BASE_URL=http://localhost:8000

# S3 / MinIO (only when STORAGE_BACKEND=s3)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=trekrank-photos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Geocoding (free, no key required)
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
GEOCODE_USER_AGENT=TrekRank/0.1 (mvp)

ENVIRONMENT=development

# Email via SendGrid Web API (no DNS needed — use Single Sender Verification).
# Leave SENDGRID_API_KEY blank to disable email; password reset then returns
# the token directly in the API response (dev only).
SENDGRID_API_KEY=
EMAIL_FROM=                       # a SendGrid-verified sender, e.g. your-name@gmail.com
EMAIL_FROM_NAME=TrekRank
FRONTEND_BASE_URL=http://127.0.0.1:8080   # where the web UI is hosted (for the reset link)

# Foursquare Places — free tier; venue popularity = live trendiness signal
FOURSQUARE_API_KEY=

